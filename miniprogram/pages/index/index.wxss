.page {
  padding: 28rpx;
}

.header {
  align-items: flex-start;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.eyebrow {
  color: #2454d6;
  display: block;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  margin-bottom: 8rpx;
}

.title {
  color: #18202f;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.15;
}

.subtitle {
  color: #667085;
  font-size: 24rpx;
  line-height: 1.5;
  margin-top: 10rpx;
}

.refresh {
  flex: 0 0 auto;
}

.status {
  display: grid;
  gap: 14rpx;
  grid-template-columns: repeat(3, 1fr);
  margin-bottom: 20rpx;
}

.status > view,
.card {
  background: #ffffff;
  border: 1rpx solid #d9e0ea;
  border-radius: 14rpx;
  box-shadow: 0 10rpx 28rpx rgba(31, 45, 61, 0.06);
}

.status > view {
  padding: 18rpx;
}

.label {
  color: #667085;
  display: block;
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.value {
  color: #18202f;
  font-size: 30rpx;
  font-weight: 800;
}

.danger,
.positive {
  color: #c83d3d;
}

.negative {
  color: #177245;
}

.neutral {
  color: #667085;
}

.add {
  align-items: center;
  background: #ffffff;
  border: 1rpx solid #d9e0ea;
  border-radius: 14rpx;
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding: 12rpx;
}

.add input {
  flex: 1;
  min-height: 72rpx;
  padding: 0 12rpx;
}

.add button {
  flex: 0 0 150rpx;
}

.error {
  background: #fff0f0;
  border-radius: 12rpx;
  color: #c83d3d;
  margin-bottom: 18rpx;
  padding: 18rpx;
}

.notice {
  margin: 16rpx 0;
  padding: 18rpx 20rpx;
  border: 1rpx solid #f0c36d;
  border-radius: 12rpx;
  background: #fff8e6;
  color: #7a4d00;
  font-size: 24rpx;
}

.fund-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.card {
  overflow: hidden;
  padding: 22rpx;
}

.card.alert {
  border-color: #f1b8b8;
}

.card-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.code {
  color: #2454d6;
  font-size: 28rpx;
  font-weight: 800;
  margin-right: 14rpx;
}

.name {
  color: #18202f;
  font-size: 30rpx;
  font-weight: 800;
}

.remove {
  background: #f4f6f9;
  color: #667085;
}

.metrics {
  display: grid;
  gap: 14rpx;
  grid-template-columns: repeat(2, 1fr);
}

.metrics > view {
  background: #f6f8fb;
  border-radius: 12rpx;
  padding: 16rpx;
}

.subgrid {
  color: #667085;
  display: grid;
  font-size: 24rpx;
  gap: 10rpx;
  grid-template-columns: repeat(2, 1fr);
  margin-top: 18rpx;
}

.hint {
  color: #667085;
  font-size: 23rpx;
  line-height: 1.6;
  padding: 26rpx 6rpx;
}
